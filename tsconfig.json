{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
"lib": [
      "dom",
      "dom.iterable",
      "ESNext"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
     "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src",
    "node_modules/@stacks/clarinet-sdk/vitest-helpers/src",
    "tests",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}
